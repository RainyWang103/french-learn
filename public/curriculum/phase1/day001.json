  "grammar": {
    "standard": {
      "title": "Subject Pronouns + Être (to be)",
      "explanation": "In French, 'être' (to be) is one of the most important verbs. It is irregular, meaning its forms don't follow a regular pattern. You use it to describe states and feelings, like 'je suis fatigué' (I am tired). The subject pronouns are: je (I), tu (you informal), il/elle (he/she), nous (we), vous (you formal/plural), ils/elles (they).",
      "examples": [
        {
          "french": "Je suis fatigué.",
          "english": "I am tired."
        },
        {
          "french": "Tu es dans le lit.",
          "english": "You are in bed."
        },
        {
          "french": "Elle est prête le matin.",
          "english": "She is ready in the morning."
        },
        {
          "french": "Nous sommes fatigués.",
          "english": "We are tired."
        }
      ],
      "drills": [
        {
          "type": "fillInTheBlank",
          "question": "Je ___ fatigué. (être)",
          "correctAnswer": "suis",
          "explanation": "Je + être = je suis"
        },
        {
          "type": "fillInTheBlank",
          "question": "Tu ___ dans le lit. (être)",
          "correctAnswer": "es",
          "explanation": "Tu + être = tu es"
        },
        {
          "type": "fillInTheBlank",
          "question": "Elle ___ prête. (être)",
          "correctAnswer": "est",
          "explanation": "Il/elle + être = il/elle est"
        },
        {
          "type": "fillInTheBlank",
          "question": "Nous ___ fatigués le matin. (être)",
          "correctAnswer": "sommes",
          "explanation": "Nous + être = nous sommes"
        },
        {
          "type": "fillInTheBlank",
          "question": "Vous ___ dans le lit ? (être)",
          "correctAnswer": "êtes",
          "explanation": "Vous + être = vous êtes"
        }
      ]
